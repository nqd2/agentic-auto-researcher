# LLM (OpenAI-compatible or Anthropic via proxy — see PROVIDER_STYLE)
PROVIDER_URL=https://api.openai.com/v1
API_KEY=
# openai | anthropic
PROVIDER_STYLE=openai
MODEL=gpt-4o-mini

# Playwright / Chrome (optional)
CHROME_EXECUTABLE_PATH=
CHROME_USER_PROFILE=

# Memory backends (optional — omit to run degraded)
REDIS_URL=redis://127.0.0.1:6379
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=aar_memory
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# LSP (optional path to language server or workspace root for future indexer)
LSP_WORKSPACE_ROOT=
